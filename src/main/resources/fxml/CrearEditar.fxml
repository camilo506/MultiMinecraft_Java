<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane styleClass="crear-editar-root"
            style="-fx-background-color: #131c28; -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1; -fx-border-radius: 12;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.multiminecraft.launcher.controller.CrearEditarController"
            prefWidth="460" prefHeight="550">

    <top>
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets bottom="10" left="22" right="22" top="18" />
            </padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="Crear Nueva Instancia"/>
                <Label text="Configura tu entorno de juego personalizado." style="-fx-font-size: 11px; -fx-text-fill: #6b7b8d;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="closeBtn" onAction="#onCancel" style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: #8899aa; -fx-background-radius: 8; -fx-padding: 5 10; -fx-cursor: hand; -fx-font-size: 11px;" text="✕" />
        </HBox>
    </top>

    <center>
        <VBox styleClass="crear-editar-content">
            <padding>
                <Insets top="24" right="28" bottom="20" left="28"/>
            </padding>

            <Region prefHeight="4"/>

            <Region prefHeight="16"/>

            <HBox spacing="20" alignment="TOP_LEFT">
                <VBox spacing="10" alignment="CENTER">
                    <Label text="ICONO" styleClass="field-label"/>
                    <StackPane prefWidth="90" prefHeight="90">
                        <ImageView fx:id="iconPreview" fitWidth="80" fitHeight="80" preserveRatio="true"/>
                        <Label fx:id="iconPlaceholder" text="🖼" styleClass="icon-placeholder-label" />
                    </StackPane>
                    <Button text="SELECCIONAR" onAction="#onBrowseIcon" styleClass="btn-select-icon" />
                </VBox>

                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <VBox spacing="5">
                        <Label text="NOMBRE DE INSTANCIA" styleClass="field-label"/>
                        <TextField fx:id="nameField" styleClass="input-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="NOMBRE DEL JUGADOR" styleClass="field-label"/>
                        <TextField fx:id="playerNameField" styleClass="input-field" maxWidth="Infinity"/>
                    </VBox>
                </VBox>
            </HBox>

            <Region prefHeight="16"/>

            <HBox alignment="CENTER" spacing="10">
                <VBox spacing="5">
                    <Label text="VERSIÓN" styleClass="field-label"/>
                    <ComboBox fx:id="versionComboBox" prefWidth="110" styleClass="input-combo"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="TIPO" styleClass="field-label"/>
                    <ComboBox fx:id="loaderTypeComboBox" prefWidth="110" styleClass="input-combo"/>
                </VBox>
            </HBox>

            <Region prefHeight="16"/>

            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT">
                    <Label text="MEMORIA RAM" styleClass="field-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="memoryLabel" text="2GB" />
                </HBox>
                <Slider fx:id="memorySlider" min="1" max="16" value="2" maxWidth="Infinity"
                        styleClass="ram-slider" showTickLabels="true" showTickMarks="true"
                        majorTickUnit="1" minorTickCount="0" snapToTicks="true"/>
            </VBox>

            <Region prefHeight="16"/>

            <!-- SECCIÓN: SKIN (Simplificada al extremo) -->
            <VBox spacing="8">
                <Label text="SKIN (OPCIONAL)" styleClass="field-label"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="96" prefHeight="140" style="-fx-background-color: #1a2332; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 10;">
                        <ImageView fx:id="skinPreview" fitWidth="78" fitHeight="128" preserveRatio="false" smooth="false" />
                        <Label fx:id="skinPlaceholder" text="👤" />
                    </StackPane>
                    <VBox spacing="5">
                        <Label fx:id="skinNameLabel" text="Global" styleClass="crear-subtitle" />
                        <HBox spacing="5">
                            <Button fx:id="btnBrowseSkin" text="Elegir" onAction="#onBrowseSkin" styleClass="btn-select-icon" disable="true" />
                            <Button fx:id="btnRemoveSkin" text="🗑" onAction="#onRemoveSkin" styleClass="btn-cancel" />
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#onCancel" styleClass="btn-cancel" />
                <Button fx:id="createButton" text="Crear Instancia" onAction="#onCreate" styleClass="btn-create" />
            </HBox>
        </VBox>
    </center>

    <bottom>
        <VBox fx:id="progressContainer" visible="false" managed="false" alignment="CENTER">
            <ProgressIndicator fx:id="progressBar" />
            <Label fx:id="progressPercentLabel" text="" />
            <Label fx:id="progressLabel" text="" />
        </VBox>
    </bottom>

</BorderPane>
