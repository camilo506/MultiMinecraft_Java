<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane styleClass="root-pane, crear-editar-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.multiminecraft.launcher.controller.CrearEditarController"
            prefWidth="460" prefHeight="520">

    <!-- Barra de título personalizada -->
    <top>
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="0" styleClass="custom-title-bar">
            <padding>
                <Insets bottom="0" left="12" right="0" top="0" />
            </padding>
            <Label styleClass="title-bar-text" text="MultiMinecraft" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="minimizeBtn" onAction="#onMinimizeClicked" styleClass="title-bar-button" text="—" />
            <Button fx:id="closeBtn" onAction="#onCloseClicked" styleClass="title-bar-button, close-button" text="✕" />
        </HBox>
    </top>

    <center>
        <VBox styleClass="crear-editar-content">
            <padding>
                <Insets top="24" right="28" bottom="20" left="28"/>
            </padding>

            <!-- Header: Título -->
            <VBox spacing="4">
                <Label fx:id="titleLabel" text="Crear Nueva Instancia" styleClass="crear-title"/>
                <Label text="Configura tu entorno de juego personalizado para MultiMinecraft Launcher." styleClass="crear-subtitle"/>
            </VBox>

            <!-- Separador visual -->
            <Region prefHeight="16"/>

            <!-- Sección: Icono + Nombre de instancia / Jugador -->
            <HBox spacing="20" alignment="TOP_LEFT">

                <!-- Columna izquierda: Icono -->
                <VBox spacing="10" alignment="CENTER" styleClass="icon-section">
                    <Label text="ICONO" styleClass="field-label"/>
                    <StackPane styleClass="icon-preview-container" prefWidth="90" prefHeight="90">
                        <ImageView fx:id="iconPreview" fitWidth="80" fitHeight="80" preserveRatio="true"/>
                        <Label fx:id="iconPlaceholder" text="🖼" styleClass="icon-placeholder-label"/>
                    </StackPane>
                    <Button text="SELECCIONAR" onAction="#onBrowseIcon" styleClass="btn-select-icon"/>
                </VBox>

                <!-- Columna derecha: Campos de texto -->
                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <!-- Nombre de instancia -->
                    <VBox spacing="5">
                        <Label text="NOMBRE DE INSTANCIA" styleClass="field-label"/>
                        <TextField fx:id="nameField" promptText="Mi Aventura Survival" styleClass="input-field" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Nombre del jugador -->
                    <VBox spacing="5">
                        <Label text="NOMBRE DEL JUGADOR" styleClass="field-label"/>
                        <TextField fx:id="playerNameField" promptText="Steve_Player" styleClass="input-field" maxWidth="Infinity"/>
                    </VBox>
                </VBox>
            </HBox>

            <Region prefHeight="16"/>

            <!-- Fila: Versión de Minecraft + Tipo (grupo junto y centrado) -->
            <HBox alignment="CENTER">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <VBox spacing="5" alignment="TOP_CENTER">
                        <Label text="VERSIÓN DE MINECRAFT" styleClass="field-label"/>
                        <HBox spacing="0" styleClass="combo-wrapper" alignment="CENTER" maxWidth="Infinity">
                            <ComboBox fx:id="versionComboBox" promptText="Release 1.20.4" styleClass="input-combo" prefWidth="110" maxWidth="110"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="5" alignment="TOP_CENTER">
                        <Label text="TIPO" styleClass="field-label"/>
                        <HBox spacing="0" styleClass="combo-wrapper" alignment="CENTER" maxWidth="Infinity">
                            <ComboBox fx:id="loaderTypeComboBox" promptText="Vanilla" styleClass="input-combo" prefWidth="110" maxWidth="110"/>
                        </HBox>
                    </VBox>
                </HBox>
            </HBox>

            <Region prefHeight="16"/>

            <!-- Memoria RAM -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT">
                    <Label text="MEMORIA RAM" styleClass="field-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox alignment="CENTER_RIGHT" spacing="4">
                        <Label fx:id="memoryLabel" text="2GB" styleClass="ram-value-label"/>
                        <Label text="ASIGNADOS" styleClass="ram-asignados-label"/>
                    </HBox>
                </HBox>
                <Slider fx:id="memorySlider" min="1" max="16" value="2"
                        showTickLabels="true" showTickMarks="false"
                        majorTickUnit="4" minorTickCount="3"
                        styleClass="ram-slider" maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Botones de acción -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#onCancel" styleClass="btn-cancel"/>
                <Button fx:id="createButton" text="Crear Instancia" styleClass="btn-create" onAction="#onCreate"/>
            </HBox>
        </VBox>
    </center>

    <!-- Indicador de progreso -->
    <bottom>
        <VBox fx:id="progressContainer" styleClass="creation-progress-container" spacing="8"
              visible="false" managed="false" alignment="CENTER">
            <padding>
                <Insets top="12" right="20" bottom="12" left="20"/>
            </padding>
            <StackPane>
                <ProgressIndicator fx:id="progressBar" prefWidth="48" prefHeight="48"/>
                <Label fx:id="progressPercentLabel" text="" styleClass="progress-percent-label" mouseTransparent="true"/>
            </StackPane>
            <Label fx:id="progressLabel" text="Creando instancia..." styleClass="progress-status-label"/>
        </VBox>
    </bottom>

</BorderPane>
