<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="460.0" prefWidth="400.0" styleClass="descarga-root"
           xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.multiminecraft.launcher.controller.DescargaProgresoController">

    <VBox alignment="TOP_CENTER" maxWidth="400.0" minWidth="360.0" spacing="0.0" styleClass="descarga-card">
        <padding>
            <Insets bottom="28.0" left="32.0" right="32.0" top="36.0" />
        </padding>

        <!-- === Anillo de Progreso === -->
        <StackPane alignment="CENTER" prefHeight="160.0" prefWidth="160.0" styleClass="progress-ring-wrapper">
            <!-- Aro de fondo -->
            <Pane maxHeight="140.0" maxWidth="140.0" prefHeight="140.0" prefWidth="140.0" styleClass="progress-track-pane" />

            <!-- Indicador de progreso (Arco verde) -->
            <ProgressIndicator fx:id="progressIndicator" maxHeight="140.0" maxWidth="140.0"
                               prefHeight="140.0" prefWidth="140.0" progress="0.0"
                               styleClass="descarga-progress-indicator" />

            <!-- Texto central del porcentaje -->
            <VBox alignment="CENTER" mouseTransparent="true" prefHeight="140.0" prefWidth="140.0" spacing="1.0">
                <HBox alignment="CENTER" spacing="1.0">
                    <Label fx:id="percentLabel" styleClass="percent-number" text="0" />
                    <Label styleClass="percent-symbol" text="\%" />
                </HBox>
                <Label styleClass="progress-word-label" text="PROGRESS" />
            </VBox>
        </StackPane>

        <Region prefHeight="22.0" />

        <!-- Título del estado -->
        <Label fx:id="statusTitleLabel" alignment="CENTER" maxWidth="320.0" prefWidth="320.0"
               styleClass="descarga-status-title" text="Iniciando descarga..." textAlignment="CENTER" wrapText="true" />

        <Region prefHeight="8.0" />

        <!-- Detalle del estado -->
        <Label fx:id="statusDetailLabel" alignment="CENTER" maxWidth="310.0" prefWidth="310.0"
               styleClass="descarga-status-detail" text="Preparando el entorno..." textAlignment="CENTER" wrapText="true" />

        <Region prefHeight="26.0" />

        <!-- Estadísticas -->
        <HBox alignment="CENTER" maxWidth="320.0" prefWidth="320.0" spacing="12.0">
            <VBox minWidth="120.0" styleClass="stat-box" HBox.hgrow="ALWAYS">
                <Label styleClass="stat-label" text="VELOCIDAD" />
                <Label fx:id="speedLabel" styleClass="stat-value" text="0.0 MB/s" />
            </VBox>
            <VBox minWidth="120.0" styleClass="stat-box" HBox.hgrow="ALWAYS">
                <Label styleClass="stat-label" text="TIEMPO RESTANTE" />
                <Label fx:id="timeLabel" styleClass="stat-value" text="Calculando..." />
            </VBox>
        </HBox>

        <Region prefHeight="24.0" />

        <!-- Botón Cancelar -->
        <Button fx:id="cancelButton" maxWidth="320.0" onAction="#onCancelClicked"
                prefWidth="320.0" styleClass="btn-cancel-download" text="CANCELAR" />
    </VBox>
</StackPane>
