<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="660.0" maxWidth="1080.0" minHeight="660.0" minWidth="1080.0" prefHeight="660.0" prefWidth="1080.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.multiminecraft.launcher.controller.MainController">
    
    <!-- Barra de título personalizada -->
    <top>
        <BorderPane fx:id="titleBar" maxWidth="1080" prefHeight="42" styleClass="custom-title-bar">
            <padding>
                <Insets bottom="0" left="24" right="20" top="0" />
            </padding>
            <left>
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label styleClass="title-bar-brand" text="MultiMinecraft" />
                    <Label styleClass="title-bar-link" text="SOPORTE" />
                </HBox>
            </left>
            <right>
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <!-- Controles de la ventana (Minimizar, Maximizar, Cerrar) -->
                    <HBox alignment="CENTER_RIGHT" spacing="0">
                        <Button fx:id="minimizeBtn" onAction="#onMinimizeClicked" styleClass="title-bar-button" text="—" />
                        <Button fx:id="maximizeBtn" onAction="#onMaximizeClicked" styleClass="title-bar-button" text="☐" />
                        <Button fx:id="closeBtn" onAction="#onCloseClicked" styleClass="title-bar-button, close-button" text="✕" />
                    </HBox>
                </HBox>
            </right>
        </BorderPane>
    </top>
    <left>
        <!-- ============================================== -->
        <!-- PANEL LATERAL IZQUIERDO (SIDEBAR)              -->
        <!-- ============================================== -->
        <VBox maxWidth="200" minWidth="200" prefWidth="200" spacing="0" styleClass="sidebar" BorderPane.alignment="CENTER">
            
            <!-- 1. Botones de Navegación del menú (Jugar, Modpacks, etc) -->
            <VBox spacing="2" styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="8" left="0" right="0" top="150" />  <!-- botones del panel lateral   -->
                </padding>
                <Button fx:id="navPlayButton" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavPlayClicked" prefHeight="40" styleClass="nav-button, nav-button-active" text="  ▶  Jugar" />
                <Button fx:id="navModpacksButton" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavModpacksClicked" prefHeight="40" styleClass="nav-button" text="  📦  Modpacks" />
                <Button fx:id="navResourcePacksButton" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavResourcePacksClicked" prefHeight="40" styleClass="nav-button" text="  ✦  Res. Packs" />
                <Button fx:id="navMapsButton" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavMapsClicked" prefHeight="40" styleClass="nav-button" text="  🗺  Maps" />
                <Button fx:id="navConfigButton" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavConfigClicked" prefHeight="40" styleClass="nav-button" text="  ⚙  Config" />
            </VBox>
            <Region prefHeight="268.0" prefWidth="100.0" VBox.vgrow="ALWAYS" />
            
            <!-- 2. Perfil del Jugador (Avatar y nombre en la parte inferior) -->
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="player-panel">
                <padding>
                    <Insets bottom="10" left="12" right="12" top="10" />
                </padding>
                <ImageView fx:id="playerAvatar" fitHeight="32" fitWidth="32" preserveRatio="true" styleClass="player-avatar" />
                <VBox spacing="1">
                    <Label fx:id="playerNameLabel" styleClass="player-name-label" text="legolas" />
                    <Label styleClass="player-status-label" text="ACTIVA" />
                </VBox>
            </HBox>
            <!-- 3. Botón para crear nueva instancia -->
            <VBox styleClass="sidebar-bottom">
                <padding>
                    <Insets bottom="12" left="10" right="10" top="6" />
                </padding>
                <Button fx:id="createInstanceButton" maxWidth="Infinity" onAction="#onCreateInstanceClicked" prefHeight="38" styleClass="create-instance-button" text="+ Instancia" />
            </VBox>
        </VBox>
    </left>
   <center>
        <!-- ============================================== -->
        <!-- ÁREA CENTRAL (CONTENIDO PRINCIPAL)             -->
        <!-- ============================================== -->
        <HBox alignment="TOP_LEFT" prefHeight="970.0" prefWidth="1024.0" spacing="0" BorderPane.alignment="CENTER" style="-fx-background-color: #131c28;">
            
            <!-- Contenedor del panel principal -->
            <VBox maxWidth="900" minWidth="800" spacing="0" styleClass="main-content" HBox.hgrow="ALWAYS">
                <padding>
                    <!-- Aquí puedes cambiar 'top' para empujar TODO el contenido hacia abajo -->
                    <Insets bottom="0" left="0" right="0" top="0" />
                </padding>
                
                <!-- A. Sección del Banner (Imagen superior destacada) -->
                <VBox alignment="TOP_CENTER" spacing="0">
                    <padding>
                        <Insets bottom="0" left="0" right="0" top="0" />
                    </padding>
                    <StackPane fx:id="heroBanner" maxHeight="400" maxWidth="873" styleClass="hero-banner">  <!-- espesie de panel donde esta la imagen -->
                        <!-- Aquí puedes cambiar fitWidth (ancho), fitHeight (alto), translateX (mover izq/der) y translateY (mover arriba/abajo) -->
                        <ImageView fx:id="heroBannerImage" fitWidth="873" fitHeight="400" translateX="0" translateY="0" preserveRatio="false" styleClass="hero-banner-image" StackPane.alignment="CENTER">
                            <Image url="@../recursos2/banner-hero.png" />
                        </ImageView>
                        <Region styleClass="hero-banner-overlay" maxWidth="873" translateX="0" />
                        <VBox alignment="BOTTOM_LEFT" prefHeight="850.0" prefWidth="1024.0" spacing="4" styleClass="hero-banner-content" StackPane.alignment="BOTTOM_LEFT">
                            <padding>
                                <Insets bottom="16" left="20" right="20" top="10" />
                            </padding>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label styleClass="hero-badge" text="ÚLTIMA" />
                                <Label fx:id="lastPlayedLabel" styleClass="hero-time" text="hace 2 horas" />
                            </HBox>
                            <Label style="-fx-font-size: 24px;" styleClass="hero-title" text="Biblioteca" />
                            <Label fx:id="heroSubtitle" style="-fx-font-size: 11px; -fx-text-fill: #8899aa;" styleClass="hero-subtitle" text="Vuelve a tu aventura." />
                        </VBox>
                    </StackPane>
                </VBox>
                
                <!-- B. Sección de la Lista de Instancias (Cuadrícula del medio) -->
                <!-- Puedes cambiar 'translateY' para mover el panel hacia abajo, o 'maxHeight' para hacer que sea más corto -->
                <VBox spacing="0" styleClass="instances-section" VBox.vgrow="ALWAYS" translateY="0" maxHeight="Infinity">
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="instances-header">
                        <padding>
                            <Insets bottom="4" left="20" right="20" top="4" />
                        </padding>
                        <Label styleClass="section-title" text="Instancias" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="viewGridButton" onAction="#onViewGridClicked" styleClass="view-mode-button, view-mode-active" text="⊞" />
                    </HBox>
                    
                    <ScrollPane fx:id="instancesScrollPane" fitToHeight="true" fitToWidth="true" maxHeight="200" styleClass="instances-scroll" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="16" left="20" right="20" top="4" />
                        </padding>
                        <FlowPane fx:id="instancesGrid" alignment="TOP_LEFT" hgap="12" prefWrapLength="460" styleClass="instances-grid" vgap="12">
                            <padding>
                                <Insets bottom="10" left="0" right="0" top="4" />
                            </padding>
                        </FlowPane>
                    </ScrollPane>
                </VBox>
                
                <!-- C. Barra de Progreso (Visible solo cuando se lanza/descarga algo) -->
                <HBox fx:id="progressContainer" alignment="CENTER_LEFT" spacing="10" visible="false">
                    <VBox.margin>
                        <Insets bottom="12" left="20" right="20" top="8" />
                    </VBox.margin>
                    <ProgressBar fx:id="progressBar" maxWidth="Infinity" prefHeight="8" styleClass="progress-bar" HBox.hgrow="ALWAYS" />
                    <Label fx:id="progressLabel" styleClass="progress-label" text="0%" />
                </HBox>
            </VBox>
        </HBox>
   </center>
</BorderPane>
