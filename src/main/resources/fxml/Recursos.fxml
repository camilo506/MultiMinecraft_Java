<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="379.0" prefWidth="400.0" spacing="15" styleClass="background-primary" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.multiminecraft.launcher.controller.RecursosController">
    
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER" spacing="10">
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="titleLabel" styleClass="label-title" text="Recursos" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onClose" style="-fx-background-color: transparent; -fx-text-fill: -fx-text-base-color;" text="✕" />
    </HBox>
    
    <Separator />
    
    <!-- Botones de recursos -->
    <VBox spacing="6" VBox.vgrow="ALWAYS">
        <Button fx:id="modPackButton" maxWidth="Infinity" onAction="#onModPackClicked" prefHeight="28" styleClass="action-button" text="ModPack" />
        <Button fx:id="modButton" maxWidth="Infinity" onAction="#onModClicked" prefHeight="28" styleClass="action-button" text="Mod" />
        <Button fx:id="shadersButton" maxWidth="Infinity" onAction="#onShadersClicked" prefHeight="28" styleClass="action-button" text="Shaders" />
        <Button fx:id="resourcePacksButton" maxWidth="Infinity" onAction="#onResourcePacksClicked" prefHeight="28" styleClass="action-button" text="ResourcePacks" />
    </VBox>
    
</VBox>
